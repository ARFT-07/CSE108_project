<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="720" prefWidth="1100" style="-fx-background-color: #1a1a2e;" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/25" fx:controller="org.buet.fantasymanagerxi.PlayerDBController">

    <!-- TOP BAR -->
    <top>
        <VBox style="-fx-background-color: #16213e; -fx-padding: 16;">
            <HBox alignment="CENTER_LEFT" spacing="16">
                <Button fx:id="backBtn" onAction="#goBack" style="-fx-background-color: transparent;                                -fx-text-fill: #aaaaaa; -fx-font-size:14;                                -fx-cursor: hand;" text="← Back" />
                <Label style="-fx-text-fill: white; -fx-font-size: 22;                               -fx-font-weight: bold;" text="⚽ Player Database" />
                <HBox HBox.hgrow="ALWAYS" />
                <TextField fx:id="searchField" prefWidth="260" promptText="Search player name..." style="-fx-background-color: #0f3460;                                   -fx-text-fill: white;                                   -fx-prompt-text-fill: #888;                                   -fx-background-radius: 20;                                   -fx-padding: 8 14 8 14;                                   -fx-font-size: 13;                                   -fx-border-color: #e94560;                                   -fx-border-radius: 20;" />
            </HBox>

            <!-- FILTERS -->
            <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 12 0 0 0;">
                <!-- Club filter -->
                <ComboBox fx:id="clubFilter" prefWidth="180" promptText="All Clubs" style="-fx-background-color: #0f3460;                                  -fx-text-fill: white;" />

                <!-- Position filter toggle buttons -->
                <ToggleButton fx:id="btnAll" onAction="#filterPosition" selected="true" styleClass="pos-btn" text="ALL" userData="ALL" />
                <ToggleButton fx:id="btnGK" onAction="#filterPosition" styleClass="pos-btn" text="GK" userData="GK" />
                <ToggleButton fx:id="btnDEF" onAction="#filterPosition" styleClass="pos-btn" text="DEF" userData="DEF" />
                <ToggleButton fx:id="btnMID" onAction="#filterPosition" styleClass="pos-btn" text="MID" userData="MID" />
                <ToggleButton fx:id="btnFWD" onAction="#filterPosition" styleClass="pos-btn" text="FWD" userData="FWD" />

                <HBox HBox.hgrow="ALWAYS" />
                <Label fx:id="countLabel" style="-fx-text-fill: #888; -fx-font-size: 13;" text="96 players" />
                <Button fx:id="marketBtn" text="Transfer Market"
                        onAction="#openMarket"
                        style="-fx-background-color: #e94560; -fx-text-fill: white;
               -fx-background-radius: 6; -fx-padding: 8 16;
               -fx-cursor: hand; -fx-font-weight: bold;"/>
            </HBox>
        </VBox>
    </top>

    <!-- PLAYER GRID -->
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background: #1a1a2e;                            -fx-background-color: #1a1a2e;">
            <FlowPane fx:id="playerGrid" hgap="14" style="-fx-background-color: #1a1a2e;                              -fx-padding: 20;" vgap="14" />
        </ScrollPane>
    </center>
</BorderPane>
