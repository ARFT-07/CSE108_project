<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="760.0" prefWidth="1200.0" style="-fx-background-color: #0f172a;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.buet.fantasymanagerxi.ScoutPlayersController">
   <top>
      <VBox spacing="10.0" style="-fx-background-color: #111827; -fx-padding: 18 24;">
         <children>
            <HBox alignment="CENTER_LEFT" spacing="12.0">
               <children>
                  <Button mnemonicParsing="false" onAction="#goHome" style="-fx-background-color: #374151; -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 8 16;" text="Home" />
                  <Label text="Scout Players" style="-fx-text-fill: white; -fx-font-size: 24; -fx-font-weight: bold;" />
                  <Label fx:id="clubLabel" style="-fx-text-fill: #93c5fd; -fx-font-size: 13;" />
                  <Region HBox.hgrow="ALWAYS" />
                  <Button mnemonicParsing="false" onAction="#goToMarket" style="-fx-background-color: #7c3aed; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 16;" text="Transfer Market" />
               </children>
            </HBox>
            <HBox alignment="CENTER_LEFT" spacing="10.0">
               <children>
                  <TextField fx:id="searchField" prefWidth="260.0" promptText="Search by player or club..." style="-fx-background-color: #1e293b; -fx-text-fill: white; -fx-prompt-text-fill: #64748b; -fx-background-radius: 20; -fx-padding: 8 14;" />
                  <ToggleButton fx:id="btnAll" mnemonicParsing="false" onAction="#filterPosition" selected="true" style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-background-radius: 16; -fx-padding: 6 14;" text="ALL" userData="ALL" />
                  <ToggleButton fx:id="btnGK" mnemonicParsing="false" onAction="#filterPosition" style="-fx-background-color: #334155; -fx-text-fill: white; -fx-background-radius: 16; -fx-padding: 6 14;" text="GK" userData="GK" />
                  <ToggleButton fx:id="btnDEF" mnemonicParsing="false" onAction="#filterPosition" style="-fx-background-color: #334155; -fx-text-fill: white; -fx-background-radius: 16; -fx-padding: 6 14;" text="DEF" userData="DEF" />
                  <ToggleButton fx:id="btnMID" mnemonicParsing="false" onAction="#filterPosition" style="-fx-background-color: #334155; -fx-text-fill: white; -fx-background-radius: 16; -fx-padding: 6 14;" text="MID" userData="MID" />
                  <ToggleButton fx:id="btnFWD" mnemonicParsing="false" onAction="#filterPosition" style="-fx-background-color: #334155; -fx-text-fill: white; -fx-background-radius: 16; -fx-padding: 6 14;" text="FWD" userData="FWD" />
                  <Region HBox.hgrow="ALWAYS" />
                  <Label fx:id="countLabel" style="-fx-text-fill: #cbd5e1; -fx-font-size: 13; -fx-font-weight: bold;" text="0 players available" />
               </children>
            </HBox>
         </children>
      </VBox>
   </top>
   <center>
      <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;">
         <content>
            <FlowPane fx:id="playerGrid" hgap="16.0" style="-fx-padding: 20;" vgap="16.0" />
         </content>
      </ScrollPane>
   </center>
   <bottom>
      <HBox style="-fx-background-color: #111827; -fx-padding: 12 24;">
         <children>
            <Label fx:id="statusLabel" style="-fx-text-fill: #94a3b8; -fx-font-size: 12;" text="Scout report loading..." />
         </children>
      </HBox>
   </bottom>
</BorderPane>
