<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane prefHeight="600.0" prefWidth="1000.0"
           styleClass="login-root"
           xmlns="http://javafx.com/javafx/25"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="org.buet.fantasymanagerxi.LoginController">
   <children>
      <VBox alignment="CENTER_LEFT" maxWidth="420.0" prefWidth="420.0" spacing="12.0" styleClass="login-card">
         <padding>
            <Insets bottom="34.0" left="34.0" right="34.0" top="34.0" />
         </padding>
         <children>
            <Label text="Club Login" styleClass="login-title" />
            <Label text="Choose your club account and enter the password to continue." wrapText="true" styleClass="login-subtitle" />
            <Region prefHeight="6.0" />

            <Label text="Club" styleClass="field-label" />
            <ComboBox fx:id="clubDropdown"
                      promptText="Choose a club"
                      prefHeight="48.0"
                      prefWidth="352.0"
                      styleClass="form-combo" />
            <Label text="Select the club you want to manage." styleClass="field-help" />

            <Label text="Password" styleClass="field-label" />
            <PasswordField fx:id="passwordField"
                           promptText="Enter your password"
                           prefHeight="48.0"
                           prefWidth="352.0"
                           styleClass="form-field" />

            <Label fx:id="errorLabel"
                   text=""
                   wrapText="true"
                   minHeight="20.0"
                   styleClass="error-text" />

            <Region prefHeight="4.0" />

            <Button fx:id="loginBtn"
                    text="Login"
                    onAction="#handleLogin"
                    prefHeight="48.0"
                    prefWidth="352.0"
                    styleClass="login-button" />
         </children>
      </VBox>
   </children>
</StackPane>
