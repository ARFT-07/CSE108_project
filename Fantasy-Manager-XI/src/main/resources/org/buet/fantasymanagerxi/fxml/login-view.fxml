<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane prefHeight="600.0" prefWidth="1000.0"
           xmlns="http://javafx.com/javafx/25"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="org.buet.fantasymanagerxi.LoginController">
   <children>
      <VBox alignment="CENTER" prefWidth="340.0" spacing="20.0"
            style="-fx-background-color: #16213e;
                     -fx-background-radius: 12;
                     -fx-padding: 40;">

         <Label text="Fantasy League XI"
                style="-fx-text-fill: white; -fx-font-size: 22;
                           -fx-font-weight: bold;"/>

         <Label text="Select your club and enter password"
                style="-fx-text-fill: #aaaaaa; -fx-font-size: 13;"/>

         <!-- Club dropdown -->
         <ComboBox fx:id="clubDropdown"
                   promptText="Select Club"
                   prefWidth="260"
                   style="-fx-background-color: #0f3460;
                             -fx-text-fill: white;
                             -fx-font-size: 14;"/>

         <!-- Password -->
         <PasswordField fx:id="passwordField"
                        promptText="Enter password"
                        prefWidth="260"
                        style="-fx-background-color: #0f3460;
                                  -fx-text-fill: white;
                                  -fx-font-size: 14;
                                  -fx-padding: 10;"/>

         <!-- Error message -->
         <Label fx:id="errorLabel"
                text=""
                style="-fx-text-fill: #e94560; -fx-font-size: 12;"/>

         <!-- Login button -->
         <Button fx:id="loginBtn"
                 text="Login"
                 onAction="#handleLogin"
                 prefWidth="260"
                 style="-fx-background-color: #e94560;
                           -fx-text-fill: white;
                           -fx-font-size: 16;
                           -fx-font-weight: bold;
                           -fx-background-radius: 6;
                           -fx-padding: 10;
                           -fx-cursor: hand;"/>
      </VBox>
   </children>
</StackPane>