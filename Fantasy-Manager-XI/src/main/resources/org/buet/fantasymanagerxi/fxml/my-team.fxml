<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane
        prefWidth="1100" prefHeight="720"
        style="-fx-background-color: #060d16;"
        xmlns="http://javafx.com/javafx/21"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="org.buet.fantasymanagerxi.MyTeamController">

    <top>
        <VBox style="-fx-background-color: #0a1628;
                     -fx-border-color: #1a2d45;
                     -fx-border-width: 0 0 1 0;">
            <HBox alignment="CENTER_LEFT" spacing="16"
                  style="-fx-padding: 14 20 10 20;">
                <Button fx:id="backbtn" mnemonicParsing="false" onAction="#goBack"
                        style="-fx-background-color: transparent; -fx-text-fill: #64748b;
                           -fx-border-color: #1e293b; -fx-border-radius: 6;
                           -fx-background-radius: 6; -fx-padding: 6 14;
                           -fx-font-size: 12; -fx-cursor: hand;" text="← Back"/>
                <Region prefWidth="1" prefHeight="28"
                        style="-fx-background-color: #1e293b;"/>
                <Label style="-fx-text-fill: #1e40af; -fx-font-size: 18;" text="⚽"/>
                <VBox spacing="0">
                    <Label style="-fx-text-fill: #e2e8f0; -fx-font-size: 17;
                                  -fx-font-weight: bold;" text="MY SQUAD"/>
                    <Label style="-fx-text-fill: #334155; -fx-font-size: 10;"
                           text="Starting XI · Bench · Formation"/>
                </VBox>
                <HBox spacing="8" alignment="CENTER_LEFT"
                      style="-fx-background-color: #0f1c2c; -fx-background-radius: 8;
                             -fx-border-color: #1e293b; -fx-border-radius: 8;
                             -fx-padding: 6 14;">
                    <Label style="-fx-text-fill: #475569; -fx-font-size: 10;" text="CLUB"/>
                    <Label fx:id="clubLabel"
                           style="-fx-text-fill: #93c5fd; -fx-font-size: 12;
                                  -fx-font-weight: bold;"/>
                </HBox>
                <HBox spacing="6" alignment="CENTER"
                      style="-fx-background-color: #0f1c2c; -fx-background-radius: 8;
                             -fx-border-color: #1e293b; -fx-border-radius: 8;
                             -fx-padding: 6 14;">
                    <Label style="-fx-text-fill: #475569; -fx-font-size: 10;" text="SQUAD"/>
                    <Label fx:id="squadCountLabel"
                           style="-fx-text-fill: #94a3b8; -fx-font-size: 11;
                                  -fx-font-weight: bold;" text="— Players"/>
                </HBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="marketBtn" mnemonicParsing="false" onAction="#goToMarket"
                        style="-fx-background-color: #1d4ed8; -fx-text-fill: white;
                           -fx-background-radius: 8; -fx-padding: 9 22;
                           -fx-font-size: 12; -fx-font-weight: bold; -fx-cursor: hand;
                           -fx-effect: dropshadow(gaussian, rgba(29,78,216,0.5), 10, 0, 0, 3);"
                        text="⚡ Transfer Market"/>
            </HBox>
            <HBox fx:id="formationBar" alignment="CENTER_LEFT" spacing="8"
                  style="-fx-padding: 0 20 10 20;"/>
        </VBox>
    </top>

    <center>
        <HBox spacing="0">
            <!-- Pitch — NO hardcoded background-color; controller sets it -->
            <StackPane HBox.hgrow="ALWAYS" style="-fx-padding: 16 10 16 16;">
                <Pane fx:id="pitchPane"
                      maxHeight="1.7976931348623157E308"
                      maxWidth="1.7976931348623157E308"
                      style="-fx-background-radius: 14;
                             -fx-border-color: #1a3a10;
                             -fx-border-radius: 14;
                             -fx-border-width: 2;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.8), 20, 0, 0, 8);"/>
            </StackPane>

            <!-- Bench panel -->
            <VBox prefWidth="240" spacing="0"
                  style="-fx-background-color: #080f1a;
                         -fx-border-color: #0f1c2c;
                         -fx-border-width: 0 0 0 1;">
                <VBox style="-fx-background-color: #0a1628; -fx-padding: 14 16 12 16;
                             -fx-border-color: #1a2d45; -fx-border-width: 0 0 1 0;">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label style="-fx-text-fill: #3b82f6; -fx-font-size: 14;" text="▐"/>
                        <VBox spacing="1">
                            <Label style="-fx-text-fill: #e2e8f0; -fx-font-size: 13;
                                          -fx-font-weight: bold;" text="BENCH"/>
                            <Label style="-fx-text-fill: #334155; -fx-font-size: 9;"
                                   text="Substitutes &amp; reserves"/>
                        </VBox>
                    </HBox>
                </VBox>
                <ScrollPane fitToWidth="true" hbarPolicy="NEVER" VBox.vgrow="ALWAYS"
                            style="-fx-background: transparent; -fx-background-color: transparent;
                           -fx-border-color: transparent;">
                    <VBox fx:id="subsPanel" spacing="6" style="-fx-padding: 12;"/>
                </ScrollPane>
            </VBox>
        </HBox>
    </center>

    <bottom>
        <HBox alignment="CENTER_LEFT" spacing="10"
              style="-fx-background-color: #0a1628; -fx-border-color: #0f1c2c;
                     -fx-border-width: 1 0 0 0; -fx-padding: 8 20;">
            <Label style="-fx-background-color: #22c55e; -fx-background-radius: 4;
                          -fx-min-width: 8; -fx-min-height: 8;
                          -fx-max-width: 8; -fx-max-height: 8;" text=""/>
            <Label fx:id="statusLabel" style="-fx-text-fill: #475569; -fx-font-size: 11;"
                   text="Tap a player card to select, then tap another to swap positions."/>
            <Region HBox.hgrow="ALWAYS"/>
            <HBox spacing="10" alignment="CENTER_RIGHT">
                <Label style="-fx-background-color: #92400e; -fx-text-fill: white;
                              -fx-font-size: 9; -fx-font-weight: bold;
                              -fx-background-radius: 3; -fx-padding: 2 7;" text="GK"/>
                <Label style="-fx-background-color: #1d4ed8; -fx-text-fill: white;
                              -fx-font-size: 9; -fx-font-weight: bold;
                              -fx-background-radius: 3; -fx-padding: 2 7;" text="DEF"/>
                <Label style="-fx-background-color: #15803d; -fx-text-fill: white;
                              -fx-font-size: 9; -fx-font-weight: bold;
                              -fx-background-radius: 3; -fx-padding: 2 7;" text="MID"/>
                <Label style="-fx-background-color: #b91c1c; -fx-text-fill: white;
                              -fx-font-size: 9; -fx-font-weight: bold;
                              -fx-background-radius: 3; -fx-padding: 2 7;" text="FWD"/>
            </HBox>
        </HBox>
    </bottom>
</BorderPane>