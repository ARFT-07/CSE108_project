<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="760" prefWidth="1200" style="-fx-background-color: #080c14;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.buet.fantasymanagerxi.MyTeamController">

    <!-- ══════════════════════════════════════════════════════════════════════ -->
    <!--  TOP BAR                                                               -->
    <!-- ══════════════════════════════════════════════════════════════════════ -->
    <top>
        <VBox style="-fx-background-color: linear-gradient(to right, #0d1b2a, #1a1a2e, #0d1b2a);                      -fx-border-color: #c9a84c;                      -fx-border-width: 0 0 2 0;                      -fx-effect: dropshadow(gaussian, rgba(201,168,76,0.4), 12, 0, 0, 4);">

            <!-- Title row -->
            <HBox alignment="CENTER_LEFT" spacing="16" style="-fx-padding: 14 24 10 24;">

                <Button fx:id="backbtn" mnemonicParsing="false" onAction="#goBack" style="-fx-background-color: rgba(201,168,76,0.1);                                -fx-text-fill: #c9a84c;                                -fx-border-color: #c9a84c;                                -fx-border-radius: 8;                                -fx-background-radius: 8;                                -fx-padding: 7 16;                                -fx-font-size: 12;                                -fx-font-weight: bold;                                -fx-cursor: hand;" text="← Back" />

                <!-- Gold badge icon -->
                <Label style="-fx-text-fill: #c9a84c; -fx-font-size: 22;" text="🏆" />

                <Label style="-fx-text-fill: white;                               -fx-font-size: 22;                               -fx-font-weight: bold;                               -fx-effect: dropshadow(gaussian, rgba(201,168,76,0.6), 8, 0, 0, 2);" text="MY TEAM" />

                <Label fx:id="clubLabel" style="-fx-text-fill: #c9a84c;                               -fx-font-size: 15;                               -fx-font-weight: bold;                               -fx-padding: 3 10;                               -fx-background-color: rgba(201,168,76,0.12);                               -fx-background-radius: 20;                               -fx-border-color: rgba(201,168,76,0.4);                               -fx-border-radius: 20;" />

                <Region HBox.hgrow="ALWAYS" />

                <!-- Budget / Points display -->
                <VBox alignment="CENTER" spacing="1" />

                <Region prefWidth="20" />

                <Button fx:id="marketBtn" mnemonicParsing="false" onAction="#goToMarket" style="-fx-background-color: linear-gradient(to bottom, #c9a84c, #a0722a);                                -fx-text-fill: #0d1b2a;                                -fx-background-radius: 8;                                -fx-padding: 9 22;                                -fx-font-size: 12;                                -fx-font-weight: bold;                                -fx-cursor: hand;                                -fx-effect: dropshadow(gaussian, rgba(201,168,76,0.5), 8, 0, 0, 2);" text="⚡ Transfer Market" />
            </HBox>

            <!-- Formation row -->
            <HBox fx:id="formationBar" alignment="CENTER_LEFT" spacing="8" style="-fx-padding: 0 24 12 24;" />

        </VBox>
    </top>

    <!-- ══════════════════════════════════════════════════════════════════════ -->
    <!--  MAIN CONTENT                                                          -->
    <!-- ══════════════════════════════════════════════════════════════════════ -->
    <center>
        <HBox spacing="0">

            <!-- ── PITCH ─────────────────────────────────────────────────── -->
            <StackPane style="-fx-padding: 14 8 16 16;" HBox.hgrow="ALWAYS">
                <Pane fx:id="pitchPane" prefHeight="650" prefWidth="780" style="                           -fx-background-image: url('/org/buet/fantasymanagerxi/images/football_field.png');                           -fx-background-size: cover;                           -fx-background-position: center;                           -fx-background-repeat: no-repeat;                           -fx-background-color: #2d6a1f;                           -fx-background-radius: 14;                           -fx-border-color: rgba(201,168,76,0.5);                           -fx-border-radius: 14;                           -fx-border-width: 2;                           -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.7), 20, 0, 0, 8);                       ">
               <children>
                  <ImageView blendMode="LIGHTEN" fitHeight="620.0" fitWidth="806.0" layoutX="75.0" layoutY="-2.0" pickOnBounds="true">
                     <image>
                        <Image url="@../images/football_field.png" />
                     </image>
                  </ImageView>
               </children></Pane>
            </StackPane>

            <!-- ── BENCH PANEL ─────────────────────────────────────────── -->
            <VBox prefWidth="220" spacing="0" style="-fx-background-color: linear-gradient(to bottom, #0d1b2a, #111827);                          -fx-border-color: #c9a84c;                          -fx-border-width: 0 0 0 2;                          -fx-padding: 0;">

                <!-- Bench Header -->
                <HBox alignment="CENTER" style="-fx-background-color: linear-gradient(to right, #c9a84c, #a0722a);                              -fx-padding: 12 16;">
                    <Label style="-fx-text-fill: #0d1b2a; -fx-font-size: 13; -fx-font-weight: bold;" text="  BENCH" />
                </HBox>

                <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background: transparent; -fx-background-color: transparent; -fx-border-color: transparent;" vbarPolicy="AS_NEEDED" VBox.vgrow="ALWAYS">
                    <VBox fx:id="subsPanel" spacing="8" style="-fx-padding: 12 12 12 12;" />
                </ScrollPane>

            </VBox>

        </HBox>
    </center>

    <!-- ══════════════════════════════════════════════════════════════════════ -->
    <!--  STATUS BAR                                                            -->
    <!-- ══════════════════════════════════════════════════════════════════════ -->
    <bottom>
        <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-background-color: linear-gradient(to right, #0d1b2a, #1a1a2e, #0d1b2a);                      -fx-border-color: #c9a84c;                      -fx-border-width: 2 0 0 0;                      -fx-padding: 10 24;">
            <Label style="-fx-text-fill: #c9a84c; -fx-font-size: 14;" text="ℹ" />
            <Label fx:id="statusLabel" style="-fx-text-fill: #aaaaaa; -fx-font-size: 12;" text="Tap a player card to select, then tap another to swap positions." />
        </HBox>
    </bottom>

</BorderPane>
