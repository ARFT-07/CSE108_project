               </padding>
            </Button>
            <Button fx:id="gotomyteamplayerbtn" alignment="CENTER" contentDisplay="CENTER" mnemonicParsing="false" onAction="#movetoMyPlayers" prefHeight="70.0" prefWidth="600.0" text="MyTeam">
